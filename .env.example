# Pureservice tenant subdomain: <tenant>.pureservice.com
PURESERVICE_TENANT=vanylven

# API key from Pureservice → Administration → Security → API keys
PURESERVICE_API_KEY=replace-me

# API base path. /agent/api for agent-API-nøklar (vanlegast).
# Bruk /api for offentleg API om instansen din støttar det.
PURESERVICE_API_BASE_PATH=/agent/api

# Safety: when true (default), write tools (create/update/assign) are hidden.
# Set to "false" only when you intentionally want Claude/Ayfie to mutate data.
PURESERVICE_READ_ONLY=true

# Gateway token: when set (HTTP transport only), incoming requests must
# include header "X-MCP-Auth: <this value>". Leave empty for no auth.
# Generate one in PowerShell:
#   -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 48 | %{[char]$_})
PURESERVICE_GATEWAY_TOKEN=

# Optional tuning
# PURESERVICE_REQUESTS_PER_MINUTE=90
# PURESERVICE_DEFAULT_PAGE_SIZE=100
# PURESERVICE_TIMEOUT_SECONDS=30

# Transport (stdio for local Claude Desktop, http for Railway)
# MCP_TRANSPORT=stdio
